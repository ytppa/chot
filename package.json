{
  "name": "nothing-chat",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22.0.0",
    "npm": ">=8.0.0"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev:web",
    "dev:server": "npm run dev --workspace @nothing-chat/server",
    "dev:web": "npm run dev --workspace @nothing-chat/web",
    "dev:shared": "npm run dev --workspace @nothing-chat/shared",
    "db:install": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/pg-portable.ps1 install",
    "db:up": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/pg-portable.ps1 up",
    "db:down": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/pg-portable.ps1 down",
    "db:status": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/pg-portable.ps1 status",
    "db:logs": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/pg-portable.ps1 logs",
    "db:docker:up": "docker compose up -d postgres",
    "db:docker:down": "docker compose down",
    "db:docker:status": "docker compose ps",
    "db:docker:logs": "docker compose logs postgres",
    "db:generate": "npm run db:generate --workspace @nothing-chat/server",
    "db:migrate": "npm run db:migrate --workspace @nothing-chat/server",
    "db:seed:admin": "npm run db:seed:admin --workspace @nothing-chat/server",
    "db:seed:date-demo": "npm run db:seed:date-demo --workspace @nothing-chat/server",
    "test": "npm run test --workspace @nothing-chat/server",
    "build": "tsc -b",
    "typecheck": "tsc -b --pretty",
    "clean": "tsc -b --clean"
  },
  "devDependencies": {
    "typescript": "^5.6.2"
  }
}
